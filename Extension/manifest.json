{
  "manifest_version": 3,
  "name": "iGPlus",
  "version": "1.7.3",
  "description": "Enhance your iGPmanager experience",
  "key":"",
  "permissions": [
    "tabs",
    "identity",
    "storage",
    "scripting"
  ],
  "oauth2": {
    "client_id": "771547073964-l5tomkr9gm6eqh54avrn147g9eu6va83.apps.googleusercontent.com",
    "scopes":[
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "action": {
    "default_icon": {
      "128": "images/Icon128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "*://igpmanager.com/*"
  ],
  "icons": {
    "128": "images/Icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://igpmanager.com/*"
      ],
      "resources": [
        "*.png",
        "*.PNG",
        "*.svg",
        "*.css",
        "*.js"
      ]
    }
  ]
}